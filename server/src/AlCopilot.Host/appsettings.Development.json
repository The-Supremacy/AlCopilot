{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Messaging": {
    "Outbox": {
      "BatchSize": 20,
      "PollInterval": "00:00:01"
    }
  },
  "Authentication": {
    "Management": {
      "Authority": "http://localhost:8080/realms/alcopilot",
      "ClientId": "alcopilot-management-portal",
      "ClientSecret": "alcopilot-management-dev-secret",
      "CookieName": ".AlCopilot.Management.Auth",
      "CallbackPath": "/api/auth/management/signin-oidc",
      "SignedOutCallbackPath": "/api/auth/management/signout-callback-oidc"
    },
    "Customer": {
      "Authority": "http://localhost:8080/realms/alcopilot",
      "ClientId": "alcopilot-web-portal",
      "ClientSecret": "alcopilot-customer-dev-secret",
      "CookieName": ".AlCopilot.Customer.Auth",
      "CallbackPath": "/api/auth/customer/signin-oidc",
      "SignedOutCallbackPath": "/api/auth/customer/signout-callback-oidc",
      "RegisterPath": "/api/auth/customer/register"
    }
  },
  "Recommendation": {
    "Llm": {
      "Provider": "ollama"
    },
    "Ollama": {
      "Endpoint": "http://localhost:11434",
      "ModelId": "gemma4:e4b",
      "MaxHistoryMessages": 24,
      "EnableReadOnlyTools": false
    }
  }
}
