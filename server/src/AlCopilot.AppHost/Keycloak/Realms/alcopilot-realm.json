{
  "realm": "alcopilot",
  "enabled": true,
  "displayName": "AlCopilot",
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "registrationAllowed": true,
  "rememberMe": true,
  "roles": {
    "realm": [
      {
        "name": "admin",
        "description": "Full AlCopilot administrator access."
      },
      {
        "name": "manager",
        "description": "Management portal operator access."
      },
      {
        "name": "user",
        "description": "Authenticated end-user access."
      }
    ]
  },
  "clients": [
    {
      "clientId": "alcopilot-management-portal",
      "name": "AlCopilot Management Portal",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "alcopilot-management-dev-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "implicitFlowEnabled": false,
      "redirectUris": [
        "http://management.localhost:4173/*",
        "https://management.localhost:4173/*",
        "http://localhost:4173/*",
        "https://localhost:4173/*"
      ],
      "webOrigins": [
        "http://management.localhost:4173",
        "https://management.localhost:4173",
        "http://localhost:4173",
        "https://localhost:4173"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "protocolMappers": [
        {
          "name": "management roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "roles",
            "jsonType.label": "String"
          }
        }
      ],
      "defaultClientScopes": ["web-origins", "acr", "roles", "profile", "email"],
      "optionalClientScopes": ["address", "phone", "offline_access", "microprofile-jwt"]
    },
    {
      "clientId": "alcopilot-web-portal",
      "name": "AlCopilot Web Portal",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "alcopilot-customer-dev-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "implicitFlowEnabled": false,
      "redirectUris": ["http://localhost:4174/*", "https://localhost:4174/*"],
      "webOrigins": ["http://localhost:4174", "https://localhost:4174"],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "protocolMappers": [
        {
          "name": "customer roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "roles",
            "jsonType.label": "String"
          }
        }
      ],
      "defaultClientScopes": ["web-origins", "acr", "roles", "profile", "email"],
      "optionalClientScopes": ["address", "phone", "offline_access", "microprofile-jwt"]
    }
  ],
  "users": [
    {
      "username": "admin@alcopilot.local",
      "email": "admin@alcopilot.local",
      "enabled": true,
      "emailVerified": true,
      "firstName": "AlCopilot",
      "lastName": "Admin",
      "credentials": [
        {
          "type": "password",
          "value": "Passw0rd!",
          "temporary": false
        }
      ],
      "realmRoles": ["admin", "manager", "user"]
    },
    {
      "username": "manager@alcopilot.local",
      "email": "manager@alcopilot.local",
      "enabled": true,
      "emailVerified": true,
      "firstName": "AlCopilot",
      "lastName": "Manager",
      "credentials": [
        {
          "type": "password",
          "value": "Passw0rd!",
          "temporary": false
        }
      ],
      "realmRoles": ["manager", "user"]
    },
    {
      "username": "user@alcopilot.local",
      "email": "user@alcopilot.local",
      "enabled": true,
      "emailVerified": true,
      "firstName": "AlCopilot",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "Passw0rd!",
          "temporary": false
        }
      ],
      "realmRoles": ["user"]
    }
  ]
}
